@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">

    <div class="card p-4 shadow-sm" style="max-width: 600px; border-radius: 12px;">

        <h4 class="text-center mb-3">Политика конфиденциальности</h4>

        <p class="text-muted text-center mb-4">
            Мы уважаем вашу приватность и заботимся о безопасности данных.
        </p>

        <hr />

        <div class="mb-3">
            <h6>📌 Сбор данных</h6>
            <p class="text-muted mb-2">
                Мы собираем только необходимую информацию для работы приложения.
            </p>
        </div>

        <div class="mb-3">
            <h6>🔐 Безопасность</h6>
            <p class="text-muted mb-2">
                Все данные защищены и не передаются третьим лицам.
            </p>
        </div>

        <div class="mb-3">
            <h6>📄 Использование</h6>
            <p class="text-muted mb-2">
                Данные используются исключительно для функциональности системы.
            </p>
        </div>

        <div class="text-center mt-4">
            <a href="/" class="btn btn-outline-secondary">
                Назад
            </a>
        </div>

    </div>

</div>