@using Domain.DTOs.Cars
@model List<GetCarDto>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="m-0">Список машин</h2>

    <a href="/Cars/Create" class="btn btn-primary">
        + Создать машину
    </a>
</div>

<table class="table table-hover">
    <thead>
        <tr>
            <th>ID</th>
            <th>Модель</th>
            <th>Цена/день</th>
            <th>Доступна</th>
            <th>Бронирований</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var car in Model)
        {
            <tr>
                <td>@car.Id</td>
                <td>@car.Model</td>
                <td>@car.PricePerDay c.</td>
                <td>@(car.IsAvialable ? "Да" : "Нет")</td>
                <td>@car.BookingCount</td>
                <td>
                    <div class="d-flex gap-2">
                        <a href="/Cars/Edit/@car.Id" class="btn btn-warning btn-sm">
                            Edit
                        </a>

                        <form method="post" asp-controller="Cars" asp-action="Delete" asp-route-id="@car.Id">
                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Удалить?')">
                                Delete
                            </button>
                        </form>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>