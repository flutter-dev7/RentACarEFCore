@using MvcApp.ViewModels
@model EditCarViewModel

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg p-4" style="width: 450px; border-radius: 16px;">

        <h3 class="text-center mb-4">Редактировать машину</h3>

        <form method="post">
            <input asp-for="Id" type="hidden" />

            <div class="mb-3">
                <label class="form-label">Модель</label>
                <input asp-for="Model" class="form-control" />
                <span asp-validation-for="Model" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Цена за день</label>
                <input asp-for="PricePerDay" class="form-control" />
                <span asp-validation-for="PricePerDay" class="text-danger"></span>
            </div>

            <div class="form-check mb-4">
                <input asp-for="IsAvialable" class="form-check-input" />
                <label class="form-check-label">Доступна</label>
            </div>

            <button type="submit" class="btn btn-warning w-100">
                Сохранить изменения
            </button>
        </form>

    </div>
</div>